      const sessionId = req.headers['x-session-id'] as string;
      
      if (!sessionId) {
        throw new BadRequestException('Session ID is required');
      }
      
      await this.analyticsService.endSession(sessionId);
      
      res.status(200).json({
        success: true,
        message: 'Session ended successfully',
