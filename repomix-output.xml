    try {
      const adminId = req.userId!;
      const query = req.query;
      
      const result = await this.adminService.getLogs(adminId, query);
      
      res.status(200).json({
        success: true,
        data: result.logs,
        pagination: {
          page: result.page,
          limit: result.limit,
          total: result.total,
          pages: result.pages,
        },
      });
    } catch (error) {
      next(error);
    }
  };

