                                {{formatDate this.startDate}} - {{#if this.current}}Present{{else}}{{formatDate this.endDate}}{{/if}}
                            </div>
                        </div>
                        <div class="exp-description">{{this.description}}</div>
                        {{#if this.location}}
                            <div style="color: #888; font-size: 14px; margin-top: 4px;">📍 {{this.location}}</div>
                        {{/if}}
                    </div>
                {{/each}}
            </div>
        {{/if}}

        <!-- Education -->
        {{#if education.length}}
            <div class="section">
                <h2 class="section-title">Education</h2>
                {{#each education}}
                    <div class="education-item">
                        <div class="exp-header">
                            <div>
                                <div class="edu-institution">{{this.institution}}</div>
                                <div class="edu-degree">{{this.degree}}{{#if this.field}} - {{this.field}}{{/if}}</div>
                            </div>
                            <div class="edu-date">
                                {{formatDate this.startDate}} - {{#if this.current}}Present{{else}}{{formatDate this.endDate}}{{/if}}
                            </div>
                        </div>
                        {{#if this.gpa}}
                            <div style="color: #888; font-size: 14px; margin-top: 4px;">GPA: {{this.gpa}}</div>
                        {{/if}}
                    </div>
                {{/each}}
            </div>
        {{/if}}

        <!-- Footer -->
        <div class="footer">
            <span class="brand">Portfolio Builder</span> — Generated on {{generatedDate}}
        </div>
    </div>
</body>
</html>
