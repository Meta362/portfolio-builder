export class TelegramFormatter {
  /**
   * Format message with HTML
   */
  static formatMessage(text: string, style?: 'bold' | 'italic' | 'code'): string {
    switch (style) {
      case 'bold':
        return `<b>${text}</b>`;
      case 'italic':
        return `<i>${text}</i>`;
      case 'code':
        return `<code>${text}</code>`;
      default:
        return text;
    }
  }

  /**
   * Format help message
   */
  static getHelpMessage(language: 'en' | 'km'): string {
